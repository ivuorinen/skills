{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/ivuorinen/skills/schemas/marketplace.schema.json",
  "title": "Claude Code plugin marketplace listing",
  "description": "Schema for .claude-plugin/marketplace.json",
  "type": "object",
  "required": ["name", "owner", "plugins"],
  "additionalProperties": true,
  "properties": {
    "$schema": { "type": "string" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "owner": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" }
      },
      "additionalProperties": true
    },
    "plugins": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "source", "version"],
        "additionalProperties": true,
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+(?:[-+].+)?$"
          },
          "source": { "type": ["string", "object"] },
          "author": {
            "type": ["object", "string"],
            "properties": {
              "name": { "type": "string" },
              "email": { "type": "string", "format": "email" }
            },
            "additionalProperties": true
          }
        }
      }
    }
  }
}
